{
  "meta": {
    "version": "1.0",
    "free_meals_per_week": 2,
    "notes": "I pasti liberi sono sempre 2 a settimana. Possono essere spostati ma non eliminati.",
    "default_protein_g": 250
  },

  "proteins": {
    "pollo":    { "label": "Carne bianca",     "g": 200, "weekly_min": 2, "weekly_max": 5,    "type": "carne_bianca" },
    "manzo":    { "label": "Carne rossa",       "g": 200,  "weekly_min": 0, "weekly_max": 1,    "type": "carne_rossa" },
    "maiale":   { "label": "Carne di maiale",   "g": null, "weekly_min": 0, "weekly_max": null, "type": "carne_rossa" },
    "pesce":    { "label": "Pesce",             "g": 200,  "weekly_min": 2, "weekly_max": 4,    "type": "pesce" },
    "uova":     { "label": "Uova",              "g": null, "weekly_min": 0, "weekly_max": 2,    "type": "uova" },
    "legumi":   { "label": "Legumi",            "g": null, "weekly_min": 2, "weekly_max": null, "type": "legumi" },
    "ricotta":  { "label": "Formaggio fresco",  "g": 90,   "weekly_min": 0, "weekly_max": 2,    "type": "latticino" },
    "formaggi": { "label": "Formaggi",          "g": null, "weekly_min": 0, "weekly_max": null, "type": "latticino" },
    "tofu":     { "label": "Tofu",              "g": 150,  "weekly_min": 0, "weekly_max": 2,    "type": "vegetale" }
  },

  "carbs": {
    "pasta":    { "label": "Pasta",      "g": 90 },
    "riso":     { "label": "Riso",       "g": 80 },
    "orzo":     { "label": "Orzo",       "g": 80 },
    "farro":    { "label": "Farro",      "g": 80 },
    "patate":   { "label": "Patate",     "g": 250 },
    "couscous": { "label": "Cous cous",  "g": 60 },
    "pane":     { "label": "Pane",       "g": 80 },
    "pizza":    { "label": "Pizza",      "g": null }
  },

  "breakfasts": {
    "A": {
      "label": "Tè + yogurt greco + semi + frutto",
      "components": [
        { "item": "Tè",                            "qty": "1 tazza" },
        { "item": "Yogurt greco",                  "qty": "1 vasetto" },
        { "item": "Semi oleosi (zucca, girasole)", "qty": "2-3 cucchiai" },
        { "item": "Frutto",                        "qty": "1 medio" }
      ]
    },
    "B": {
      "label": "Latte + cereali o biscotti + frutto",
      "components": [
        { "item": "Latte (o bevanda soia)",           "qty": "1 tazza" },
        { "item": "Cereali (5-6 cucchiai) o 4 biscotti", "qty": null },
        { "item": "Frutto",                           "qty": "1 medio" }
      ],
      "notes": "Cereali sostituibili con granola fatta in casa (3-4 cucchiai)."
    },
    "D": {
      "label": "Tè + fette biscottate con burro e marmellata + frutto",
      "components": [
        { "item": "Tè",                                      "qty": "1 tazza" },
        { "item": "Fette biscottate con burro e marmellata", "qty": "2" },
        { "item": "Frutto",                                  "qty": "1 medio" }
      ]
    },
    "C": {
      "label": "Tè + porridge d'avena + frutto",
      "components": [
        { "item": "Tè",                  "qty": "1 tazza" },
        { "item": "Fiocchi d'avena",     "qty": "50g" },
        { "item": "Latte (o soia)",      "qty": "350ml" },
        { "item": "Frutto (es. banana)", "qty": "1" }
      ],
      "notes": "Opzionale: 1 cucchiaino di miele."
    }
  },

  "snacks": {
    "morning": {
      "label": "Spuntino mattina",
      "components": [
        { "item": "Caffè",        "qty": "1 tazzina" },
        { "item": "Frutto",       "qty": "1 medio o 150g piccoli frutti" },
        { "item": "Frutta secca", "qty": "~30g (es. 20 mandorle, 5-8 noci, 2-3 cucchiai pistacchi)" }
      ]
    },
    "afternoon": {
      "label": "Spuntino pomeriggio",
      "components": [
        { "item": "Frutto",          "qty": "1 medio o 150g piccoli frutti" },
        { "item": "Yogurt scremato", "qty": "1 vasetto (ove indicato nella griglia)" }
      ]
    }
  },

  "patterns": {
    "T1": {
      "label": "Carboidrato + proteina + verdure",
      "requires": ["carb", "protein", "verdure"]
    },
    "T2": {
      "label": "Legumi + verdure",
      "requires": ["legumi", "verdure"],
      "protein_ref": "legumi",
      "notes": "Spesso accompagnato da pane."
    },
    "T3": {
      "label": "Solo verdure (minestrone / passato)",
      "requires": ["verdure"],
      "notes": "Sempre con pane. Pasto leggero."
    },
    "T4": {
      "label": "Libero",
      "requires": []
    }
  },

  "week": {
    "monday": {
      "breakfast": "A",
      "lunch": {
        "pattern": "T1",
        "protein": "pollo",
        "protein_g": 150,
        "verdure_g": 200
      },
      "dinner": {
        "pattern": "T2",
        "protein": "legumi",
        "verdure_g": 250,
        "pane": true,
         "alt": {
          "pattern": "T1",
          "protein": "pesce",
          "verdure_g": 250
        }
      }
    },
    "tuesday": {
      "breakfast": "D",
      "lunch": {
        "pattern": "T1",
        "protein": "ricotta",
        "protein_g": 90,
        "verdure_g": 250
      },
      "dinner": {
        "pattern": "T1",
        "protein": "manzo",
        "protein_g": 200,
        "verdure_g": 250,
        "pane": true,
        "alt": {
          "pattern": "T1",
          "protein": "pollo",
          "verdure_g": 250
        }
      }
    },
    "wednesday": {
      "breakfast": "B",
      "lunch": {
        "pattern": "T1",
        "protein": "pesce",
        "protein_g": 150,
        "verdure_g": 250
      },
      "dinner": {
        "pattern": "T2",
        "protein": "legumi",
        "verdure_g": 250,
        "pane": true,
        "alt": {
          "pattern": "T3",
          "verdure_g": 250,
          "pane": true
        }
      }
    },
    "thursday": {
      "breakfast": "A",
      "lunch": {
        "pattern": "T1",
        "protein": "pollo",
        "protein_g": 150,
        "protein_variants": ["100g salmone affumicato"],
        "verdure_g": 200
      },
      "dinner": {
        "pattern": "T1",
        "protein": "pesce",
        "verdure_g": 250,
        "alt": {
          "pattern": "T1",
          "protein": "pollo",
          "verdure_g": 200
        }
      }
    },
    "friday": {
      "breakfast": "B",
      "lunch": {
        "pattern": "T2",
        "protein": "legumi",
        "verdure_g": 200
      },
      "dinner": {
        "pattern": "T1",
        "protein": "uova",
        "verdure_g": 250,
        "alt": {
          "pattern": "T1",
          "protein": "pesce",
          "verdure_g": 250,
          "pane": true
        }
      }
    },
    "saturday": {
      "breakfast": "C",
      "lunch": {
        "pattern": "T1",
        "protein": "pollo",
        "protein_g": 150,
        "verdure_g": 250,
        "notes": "In alternativa: risotto con condimento a piacere + 250g verdure"
      },
      "dinner": {
        "pattern": "T4",
        "free": true
      }
    },
    "sunday": {
      "breakfast": "B",
      "lunch": {
        "pattern": "T4",
        "free": true
      },
      "dinner": {
        "pattern": "T3",
        "verdure_g": 250,
        "pane": true,
        "alt": {
          "pattern": "T1",
          "protein": "pesce",
          "verdure_g": 225
        }
      }
    }
  }
}
